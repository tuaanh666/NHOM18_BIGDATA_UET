# ============================================================
# Environment variables cho Movie Recommendation System
# ============================================================

# --- Kafka ---
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC_RATINGS=ratings-stream
KAFKA_TOPIC_RECS=recommendations

# Tốc độ phát luồng rating (events/giây). 5 = chậm để minh hoạ; tăng cao để demo real-time rõ.
STREAM_RATE_PER_SEC=200

# --- HDFS ---
HDFS_NAMENODE=hdfs://namenode:9000
HDFS_DATA_DIR=/data/movielens

# --- Spark ---
SPARK_MASTER=spark://spark-master:7077

# --- HBase ---
HBASE_HOST=hbase
HBASE_THRIFT_PORT=9090
HBASE_TABLE_RECS=user_recommendations

# --- MySQL ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=movielens
MYSQL_USER=mluser
MYSQL_PASSWORD=mlpassword
MYSQL_ROOT_PASSWORD=rootpassword

# --- ALS model hyperparameters ---
ALS_RANK=64
ALS_MAX_ITER=10
ALS_REG_PARAM=0.08
ALS_TOP_N=20

# --- Flask ---
FLASK_PORT=5000
